package com.nt.sbeans;

import java.time.LocalTime;

public class WishMessageGenerat {
	private LocalTime time;

	public WishMessageGenerat() {
		System.out.println("Wish MessageGenerator:: 0-param constructor");
	}

	public void setTime(LocalTime time) {
		System.out.println("Wish MessageGenerator.setTime(-)");
		this.time = time;
	}

//business method
	public String showWishMessage(String user) {
		System.out.println("Wish MessageGenerator.showWishMessage()");

		int hour = time.getHour();

		if (hour < 12)
			return "Good Morning::" + user;
		else if (hour < 16)
			return "Good AfterNoon::" + user;
		else if (hour < 20)
			return "Good Evening ::" + user;
		else
			return "Good Night ::" + user;
	}
}
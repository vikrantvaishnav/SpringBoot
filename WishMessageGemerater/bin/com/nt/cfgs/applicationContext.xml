<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
         http://www.springframework.org/schema/beans
         http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- cfg dependent spring bean -->
    <bean id="ltime" class="java.time.LocalTime" factory-method="now"/>

    <!-- Cfg target spring bean -->
    <!--  <bean id="wmg" class="com.nt.sbeans.WishMessageGenerator">
        <property name="time" ref="ltime"/>
    </bean>
    -->
    <bean id="wmgcon" class="com.nt.sbeans.WishMessageUsingConstructor">
        <constructor-arg name="date" ref="ltime"></constructor-arg>
    </bean>

</beans>
